# NewsAPI key - Get yours at https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# Anthropic API key - Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend API key - Get yours at https://resend.com/
RESEND_API_KEY=your_resend_api_key_here

# SEC API key - Get yours at https://sec-api.io/
SEC_API_KEY=your_sec_api_key_here

# API Ninjas key - Get yours at https://api-ninjas.com/
# Used for earnings call transcripts
NINJAS_API_KEY=your_ninjas_api_key_here

# GNews API key - Get yours at https://gnews.io/
# Used for international news in multiple languages (German, French, Swedish)
GNEWS_API_KEY=your_gnews_api_key_here

# Email configuration
EMAIL_TO=recipient@example.com
EMAIL_FROM=sender@yourdomain.com

# Optional: Custom database path (defaults to data/tracker.db)
# DB_PATH=/path/to/custom/tracker.db
