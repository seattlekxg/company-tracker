# NewsAPI key - Get yours at https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# Anthropic API key - Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SendGrid API key - Get yours at https://sendgrid.com/
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Email configuration
EMAIL_TO=recipient@example.com
EMAIL_FROM=sender@yourdomain.com

# Optional: Custom database path (defaults to data/tracker.db)
# DB_PATH=/path/to/custom/tracker.db
